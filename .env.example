# ─────────────────────────────────────────────────────────────
# Frontend environment variables (add these in Vercel Dashboard)
# ─────────────────────────────────────────────────────────────

# (Supabase removed) 

# Resend API key — for order confirmation emails (https://resend.com)
RESEND_API_KEY=re_...

# OpenAI API key — for the AI chat assistant (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# MongoDB Atlas connection string (URI)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net
MONGODB_DB=kitchub

# Google OAuth (server-side)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT secret for session cookies
JWT_SECRET=replace_with_strong_random_value

# Email from address used by Resend
EMAIL_FROM="Kitchub <orders@kitchub.com>"

# Cloudinary (for product image storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
